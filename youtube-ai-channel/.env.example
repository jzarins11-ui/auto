# Pick ONE LLM provider:

# Option A: DeepSeek (cheap, $0.14/M tokens)
# Get key: https://platform.deepseek.com/api_keys
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-...

# Option B: Anthropic Claude (original)
# Get key: https://console.anthropic.com
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# YouTube Data API (free: 10K queries/day)
# Get key: https://console.cloud.google.com -> Enable YouTube Data API v3 -> Create API key
YOUTUBE_API_KEY=AIzaSy...

# YouTube upload (OAuth 2.0 — for uploading videos)
# How to set up:
#   1. https://console.cloud.google.com -> Create Project -> Enable YouTube Data API v3
#   2. Credentials -> OAuth 2.0 Client ID -> Desktop app -> Download JSON
#   3. Save as config/youtube_credentials.json (easiest)
#   OR paste the values directly:
# YT_CLIENT_ID=your_client_id.apps.googleusercontent.com
# YT_CLIENT_SECRET=your_client_secret
#
# After running the upload script once interactively, it saves a refresh token.
# For CI/headless use, add the refresh token here too:
# YT_REFRESH_TOKEN=1//0g...) your_refresh_token
